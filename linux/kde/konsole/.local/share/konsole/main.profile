[Appearance]
AntiAliasFonts=true
BoldIntense=true
BorderWhenActive=false
ColorScheme=Catppuccin-Mocha
FocusBorderColor=0,0,0
Font=Hack Nerd Font,10,-1,5,50,0,0,0,0,0
UseFontBrailleChararacters=true
UseFontLineChararacters=false

[Cursor Options]
CursorShape=0

[General]
AlternatingBackground=2
AlternatingBars=2
DimWhenInactive=false
ErrorBackground=2
ErrorBars=2
Name=main
Parent=FALLBACK/
SemanticHints=2
TerminalColumns=300
TerminalRows=64

[Interaction Options]
AllowEscapedLinks=true
EscapedLinksSchema=http://;https://
OpenLinksByDirectClickEnabled=true
UnderlineFilesEnabled=true

[Scrolling]
HistorySize=15000
ScrollBarPosition=2

[Terminal Features]
AnimatingCursorEnabled=false
