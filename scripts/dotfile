#!/usr/bin/env bash
set -euo pipefail
shopt -s dotglob nullglob

SELF="${BASH_SOURCE[0]}"
while [ -L "$SELF" ]; do
  SELF_T="$(readlink "$SELF")"
  case "$SELF_T" in
    /*) SELF="$SELF_T" ;;
    *) SELF="$(dirname "$SELF")/$SELF_T" ;;
  esac
done
DOTFILES="$(cd "$(dirname "$SELF")/.." && pwd -P)"
TARGETS_FILE="$DOTFILES/targets"
PACKAGES_CONFIG="$DOTFILES/packages.dotfile"
PACKAGES_DOC="$DOTFILES/PACKAGES.md"
STATE_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/dotfile"
OVERRIDES_FILE="$STATE_DIR/overrides"
DRY=0
OVR_KEYS=()
OVR_VALS=()
LINK_GROUPS=()
ACTIVE_OVERRIDE_DIRS=()
CONFLICTS=()
MAP_KEYS=()
MAP_VALS=()
PACKAGE_META_KEYS=()
PACKAGE_META_VALS=()
PACKAGE_FILES_CHANGED=0

usage() {
  cat <<'EOF'
usage: dotfile <command> [args]

commands:
  link [profile] [-n]   symlink every package in the profile manifest into $HOME
  add [flags] <path>    move a live config into the repo and symlink it back
  packages              regenerate packages.dotfile and PACKAGES.md
  format [path ...]     format tracked .conf files or the selected files
  status [profile]      show link state for every file in the profile
  help                  show this help

link flags:
  -n, --dry-run                   print actions without changing anything
  --override <group>=<name|none>  pick a machine override set for a group

add flags:
  --shared (default)  --linux  --kde  --hyprland  --server  --macos
  --pkg <name>        override the package name
  --description <text>  describe the package in PACKAGES.md

examples:
  dotfile link arch-linux/kde
  dotfile link --override linux/hyprland=laptop
  dotfile add waybar
  dotfile add --description "Status bar" waybar
  dotfile add --linux zsh/conf.d/11-linux-env
  dotfile add --pkg zsh ~/.zshrc
  dotfile packages
  dotfile format
EOF
}

die() { printf 'dotfile: %s\n' "$*" >&2; exit 1; }
log() { printf '%s\n' "$*"; }

run() {
  if [ "$DRY" = 1 ]; then
    log "  would: $*"
  else
    "$@"
  fi
}

canon() {
  local p="$1" seg out="" IFS=/
  for seg in $p; do
    case "$seg" in
      ""|".") ;;
      "..") out="${out%/*}" ;;
      *) out="$out/$seg" ;;
    esac
  done
  printf '%s\n' "${out:-/}"
}

resolve_link() {
  local l="$1" t
  t="$(readlink "$l")"
  case "$t" in
    /*) canon "$t" ;;
    *) canon "$(dirname "$l")/$t" ;;
  esac
}

realpath_m() {
  local d b p
  d="$(dirname "$1")"
  b="$(basename "$1")"
  d="$(cd -P "$d" 2>/dev/null && pwd -P)" || { printf '%s\n' "$1"; return 0; }
  p="$d/$b"
  if [ -L "$p" ]; then resolve_link "$p"; else printf '%s\n' "$p"; fi
}

load_targets() {
  MAP_KEYS=()
  MAP_VALS=()
  [ -f "$TARGETS_FILE" ] || return 0
  local line key val
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in *=*) ;; *) continue ;; esac
    key="${line%%=*}"
    val="${line#*=}"
    key="${key#"${key%%[![:space:]]*}"}"
    key="${key%"${key##*[![:space:]]}"}"
    val="${val#"${val%%[![:space:]]*}"}"
    val="${val%"${val##*[![:space:]]}"}"
    val="${val/#\~/$HOME}"
    MAP_KEYS+=("$key")
    MAP_VALS+=("$val")
  done < "$TARGETS_FILE"
}

map_dst() {
  local full="$1" pkg="$2" rel="$3"
  local i key best=-1 bestlen=-1
  for i in ${MAP_KEYS[@]+"${!MAP_KEYS[@]}"}; do
    key="${MAP_KEYS[$i]}"
    if [ "$full" = "$key" ] || [ "${full#"$key"/}" != "$full" ]; then
      if [ "${#key}" -gt "$bestlen" ]; then
        best=$i
        bestlen=${#key}
      fi
    fi
  done
  if [ "$best" -ge 0 ]; then
    key="${MAP_KEYS[$best]}"
    if [ "$full" = "$key" ]; then
      printf '%s\n' "${MAP_VALS[$best]}"
    else
      printf '%s\n' "${MAP_VALS[$best]}/${full#"$key"/}"
    fi
  else
    printf '%s\n' "$HOME/.config/$pkg${rel:+/$rel}"
  fi
}

has_key_under() {
  local prefix="$1" key
  for key in ${MAP_KEYS[@]+"${MAP_KEYS[@]}"}; do
    if [ "${key#"$prefix"/}" != "$key" ]; then return 0; fi
  done
  return 1
}

no_fold() {
  case "$1" in
    "$HOME"|"$HOME/.config"|"$HOME/.local"|"$HOME/.local/share"|"$HOME/.local/bin"|"$HOME/.config/systemd"|"$HOME/.config/systemd/user") return 0 ;;
  esac
  return 1
}

conflict() { CONFLICTS+=("$1"); }

link_file() {
  local src="$1" dst="$2" cur
  if [ -L "$dst" ]; then
    cur="$(resolve_link "$dst")"
    [ "$cur" = "$src" ] && return 0
    case "$cur" in
      "$DOTFILES"/*) run rm "$dst" ;;
      *) conflict "$dst"; return 0 ;;
    esac
  elif [ -e "$dst" ]; then
    conflict "$dst"
    return 0
  fi
  run mkdir -p "$(dirname "$dst")"
  run ln -s "$src" "$dst"
  log "  link ${dst/#$HOME/\~}"
}

unfold() {
  local dst="$1" cur="$2" entry
  run rm "$dst"
  run mkdir -p "$dst"
  for entry in "$cur"/*; do
    run ln -s "$entry" "$dst/$(basename "$entry")"
  done
  log "  split ${dst/#$HOME/\~}"
}

link_dir() {
  local src="$1" dst="$2" full="$3" pkg="$4" rel="$5" cur entry name
  if [ -L "$dst" ]; then
    cur="$(resolve_link "$dst")"
    if [ "$cur" = "$src" ]; then
      if has_key_under "$full"; then
        unfold "$dst" "$cur"
      else
        return 0
      fi
    else
      case "$cur" in
        "$DOTFILES"/*)
          if [ -d "$cur" ]; then
            unfold "$dst" "$cur"
          else
            run rm "$dst"
          fi
          ;;
        *) conflict "$dst"; return 0 ;;
      esac
    fi
  fi
  if [ ! -e "$dst" ]; then
    if has_key_under "$full" || no_fold "$dst"; then
      run mkdir -p "$dst"
    else
      run mkdir -p "$(dirname "$dst")"
      run ln -s "$src" "$dst"
      log "  link ${dst/#$HOME/\~}"
      return 0
    fi
  elif [ ! -d "$dst" ]; then
    conflict "$dst"
    return 0
  fi
  for entry in "$src"/*; do
    name="$(basename "$entry")"
    walk_node "$pkg" "${rel:+$rel/}$name" "$entry" "$full/$name"
  done
}

walk_node() {
  local pkg="$1" rel="$2" src="$3" full="$4" dst
  [ "$(basename "$src")" = ".nolink" ] && return 0
  dst="$(map_dst "$full" "$pkg" "$rel")"
  if [ -d "$src" ] && [ ! -L "$src" ]; then
    link_dir "$src" "$dst" "$full" "$pkg" "$rel"
  else
    link_file "$src" "$dst"
  fi
}

link_package() {
  local pkgdir="$1" grouppkg="$2"
  walk_node "$(basename "$pkgdir")" "" "$pkgdir" "$grouppkg"
}

stale_override_link() {
  local cur="$1" base active
  case "$cur" in
    */overrides/*) ;;
    *) return 1 ;;
  esac
  base="${cur%%/overrides/*}"
  [ -d "$base/overrides" ] || return 1
  for active in ${ACTIVE_OVERRIDE_DIRS[@]+"${ACTIVE_OVERRIDE_DIRS[@]}"}; do
    case "$cur" in "$active"/*) return 1 ;; esac
  done
  return 0
}

prune() {
  local l cur
  while IFS= read -rd '' l; do
    cur="$(resolve_link "$l")"
    case "$cur" in
      "$DOTFILES"/*) ;;
      *) continue ;;
    esac
    if ! stale_override_link "$cur"; then
      [ -e "$l" ] && continue
    fi
    run rm "$l"
    log "  prune ${l/#$HOME/\~}"
  done < <(
    find "$HOME" -maxdepth 1 -type l -lname "$DOTFILES/*" -print0 2>/dev/null
    find "$HOME/.config" "$HOME/.local" -maxdepth 6 -type l -lname "$DOTFILES/*" -print0 2>/dev/null
  )
}

saved_profile() {
  if [ -f "$STATE_DIR/profile" ]; then cat "$STATE_DIR/profile"; fi
}

migrate_profile() {
  case "$1" in
    desktop/arch-linux/kde) printf 'arch-linux/kde\n' ;;
    desktop/arch-linux/kde-hyprland) printf 'arch-linux/kde-hyprland\n' ;;
    laptop/arch-linux/hyprland) printf 'arch-linux/hyprland\n' ;;
    macbook/macos) printf 'macos\n' ;;
    vps/linux) printf 'ubuntu/server\n' ;;
    *) printf '%s\n' "$1" ;;
  esac
}

resolve_profile() {
  local p="${1:-}"
  [ -n "$p" ] || p="$(saved_profile)"
  migrate_profile "$p"
}

manifest_groups() {
  local line
  while IFS= read -r line || [ -n "$line" ]; do
    line="${line%%#*}"
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [ -n "$line" ] && printf '%s\n' "$line"
  done < "$1"
  return 0
}

load_overrides() {
  OVR_KEYS=()
  OVR_VALS=()
  [ -f "$OVERRIDES_FILE" ] || return 0
  local line
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in *=*) ;; *) continue ;; esac
    OVR_KEYS+=("${line%%=*}")
    OVR_VALS+=("${line#*=}")
  done < "$OVERRIDES_FILE"
}

override_for() {
  local group="$1" i
  for i in ${OVR_KEYS[@]+"${!OVR_KEYS[@]}"}; do
    if [ "${OVR_KEYS[$i]}" = "$group" ]; then
      printf '%s\n' "${OVR_VALS[$i]}"
      return 0
    fi
  done
  return 1
}

set_override() {
  local group="$1" name="$2" i
  for i in ${OVR_KEYS[@]+"${!OVR_KEYS[@]}"}; do
    if [ "${OVR_KEYS[$i]}" = "$group" ]; then
      OVR_VALS[$i]="$name"
      return 0
    fi
  done
  OVR_KEYS+=("$group")
  OVR_VALS+=("$name")
}

save_overrides() {
  [ "$DRY" = 1 ] && return 0
  mkdir -p "$STATE_DIR"
  local i
  : > "$OVERRIDES_FILE"
  for i in ${OVR_KEYS[@]+"${!OVR_KEYS[@]}"}; do
    printf '%s=%s\n' "${OVR_KEYS[$i]}" "${OVR_VALS[$i]}" >> "$OVERRIDES_FILE"
  done
}

overrides_list() {
  local d out=""
  for d in "$DOTFILES/$1/overrides"/*/; do
    out="$out${out:+ }$(basename "${d%/}")"
  done
  printf '%s\n' "$out"
}

collect_groups() {
  local manifest="$1" group name
  LINK_GROUPS=()
  ACTIVE_OVERRIDE_DIRS=()
  while IFS= read -r group; do
    LINK_GROUPS+=("$group")
    [ -d "$DOTFILES/$group/overrides" ] || continue
    if name="$(override_for "$group")"; then
      [ "$name" = "none" ] && continue
      if [ -d "$DOTFILES/$group/overrides/$name" ]; then
        LINK_GROUPS+=("$group/overrides/$name")
        ACTIVE_OVERRIDE_DIRS+=("$DOTFILES/$group/overrides/$name")
      else
        log "  skip missing override: $group/overrides/$name"
      fi
    else
      log "  note: '$group' has machine overrides ($(overrides_list "$group")), none selected"
      log "        select one: dotfile link --override $group=<name>  (or =none)"
    fi
  done < <(manifest_groups "$manifest")
}

trim_value() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s\n' "$value"
}

package_metadata_index() {
  local key="$1" i
  for i in ${PACKAGE_META_KEYS[@]+"${!PACKAGE_META_KEYS[@]}"}; do
    if [ "${PACKAGE_META_KEYS[$i]}" = "$key" ]; then
      printf '%s\n' "$i"
      return 0
    fi
  done
  return 1
}

set_package_description() {
  local key="$1" description="$2" index
  if index="$(package_metadata_index "$key")"; then
    PACKAGE_META_VALS[$index]="$description"
  else
    PACKAGE_META_KEYS+=("$key")
    PACKAGE_META_VALS+=("$description")
  fi
}

package_description() {
  local key="$1" index
  if index="$(package_metadata_index "$key")"; then
    printf '%s\n' "${PACKAGE_META_VALS[$index]}"
  else
    printf '\n'
  fi
}

load_package_metadata() {
  PACKAGE_META_KEYS=()
  PACKAGE_META_VALS=()
  [ -f "$PACKAGES_CONFIG" ] || return 0
  local raw line current="" group name description key line_number=0
  while IFS= read -r raw || [ -n "$raw" ]; do
    line_number=$((line_number + 1))
    line="$(trim_value "$raw")"
    [ -n "$line" ] || continue
    if [ "$line" = "}" ]; then
      [ -n "$current" ] || die "packages.dotfile:$line_number: unexpected }"
      current=""
      continue
    fi
    case "$line" in
      *" {")
        [ -z "$current" ] || die "packages.dotfile:$line_number: nested group"
        group="$(trim_value "${line% \{}")"
        [ -n "$group" ] || die "packages.dotfile:$line_number: empty group"
        case "$group" in
          *[!A-Za-z0-9._/-]*) die "packages.dotfile:$line_number: invalid group: $group" ;;
        esac
        current="$group"
        continue
        ;;
    esac
    [ -n "$current" ] || die "packages.dotfile:$line_number: package outside a group"
    case "$line" in
      *" = "*)
        name="$(trim_value "${line%% = *}")"
        description="$(trim_value "${line#* = }")"
        ;;
      *)
        name="$line"
        description=""
        ;;
    esac
    [ -n "$name" ] || die "packages.dotfile:$line_number: empty package"
    case "$name" in
      *[!A-Za-z0-9._+@-]*) die "packages.dotfile:$line_number: invalid package: $name" ;;
    esac
    key="$current/$name"
    if package_metadata_index "$key" >/dev/null; then
      die "packages.dotfile:$line_number: duplicate package: $key"
    fi
    PACKAGE_META_KEYS+=("$key")
    PACKAGE_META_VALS+=("$description")
  done < "$PACKAGES_CONFIG"
  [ -z "$current" ] || die "packages.dotfile:$line_number: missing } for $current"
}

package_groups() {
  {
    printf '%s\n' shared linux/common linux/kde linux/hyprland linux/server macos
    if [ -d "$DOTFILES/environment" ]; then
      local manifest
      while IFS= read -r manifest; do
        manifest_groups "$manifest"
      done < <(find "$DOTFILES/environment" -type f -name manifest -print | LC_ALL=C sort)
    fi
  } | awk 'NF && !seen[$0]++'
}

replace_package_file() {
  local source="$1" destination="$2" label="$3"
  if [ -f "$destination" ] && cmp -s "$source" "$destination"; then
    rm "$source"
    return
  fi
  mv "$source" "$destination"
  PACKAGE_FILES_CHANGED=$((PACKAGE_FILES_CHANGED + 1))
  log "updated $label"
}

sync_packages() {
  local config_temp doc_temp group group_dir pkg_path pkg description
  local packages=()
  config_temp="$(mktemp "${TMPDIR:-/tmp}/packages.dotfile.XXXXXX")"
  doc_temp="$(mktemp "${TMPDIR:-/tmp}/PACKAGES.md.XXXXXX")"
  local wrote_group=0
  while IFS= read -r group; do
    group_dir="$DOTFILES/$group"
    [ -d "$group_dir" ] || continue
    packages=()
    while IFS= read -r pkg_path; do
      pkg="$(basename "$pkg_path")"
      if [ "$pkg" = "overrides" ]; then
        continue
      fi
      case "$pkg" in
        *[!A-Za-z0-9._+@-]*)
          rm "$config_temp" "$doc_temp"
          die "package directory has an unsupported name: $group/$pkg"
          ;;
      esac
      packages+=("$pkg")
    done < <(
      for pkg_path in "$group_dir"/*/; do
        printf '%s\n' "${pkg_path%/}"
      done | LC_ALL=C sort
    )
    [ "${#packages[@]}" -gt 0 ] || continue
    if [ "$wrote_group" = 1 ]; then
      printf '\n' >> "$config_temp"
    fi
    printf '%s {\n' "$group" >> "$config_temp"
    printf '\n## `%s`\n\n' "$group" >> "$doc_temp"
    for pkg in "${packages[@]}"; do
      description="$(package_description "$group/$pkg")"
      if [ -n "$description" ]; then
        printf '  %s = %s\n' "$pkg" "$description" >> "$config_temp"
        printf -- '- `%s` — %s\n' "$pkg" "$description" >> "$doc_temp"
      else
        printf '  %s\n' "$pkg" >> "$config_temp"
        printf -- '- `%s`\n' "$pkg" >> "$doc_temp"
      fi
    done
    printf '}\n' >> "$config_temp"
    wrote_group=1
  done < <(package_groups)
  replace_package_file "$config_temp" "$PACKAGES_CONFIG" packages.dotfile
  replace_package_file "$doc_temp" "$PACKAGES_DOC" PACKAGES.md
}

cmd_packages() {
  [ "$#" -eq 0 ] || die "usage: dotfile packages"
  PACKAGE_FILES_CHANGED=0
  load_package_metadata
  sync_packages
  if [ "$PACKAGE_FILES_CHANGED" = 0 ]; then
    log "packages are current"
  fi
}

list_profiles() {
  ( cd "$DOTFILES/environment" && find . -name manifest | sed 's|^\./||; s|/manifest$||' | sort )
}

require_manifest() {
  local profile="$1"
  local manifest="$DOTFILES/environment/$profile/manifest"
  if [ -z "$profile" ] || [ ! -f "$manifest" ]; then
    {
      if [ -z "$profile" ]; then
        echo "dotfile: no profile selected (run ./setup.sh or pass one)"
      else
        echo "dotfile: no manifest for profile '$profile'"
      fi
      echo "available profiles:"
      list_profiles | sed 's/^/  /'
    } >&2
    exit 1
  fi
  printf '%s\n' "$manifest"
}

cmd_link() {
  local profile="" spec group name
  local link_overrides=()
  while [ $# -gt 0 ]; do
    case "$1" in
      -n|--dry-run) DRY=1 ;;
      --override)
        shift
        spec="${1:-}"
        case "$spec" in
          *=*) link_overrides+=("$spec") ;;
          *) die "--override needs <group>=<name|none>" ;;
        esac
        ;;
      *) profile="$1" ;;
    esac
    shift
  done
  local saved
  saved="$(saved_profile)"
  profile="$(resolve_profile "$profile")"
  local manifest
  manifest="$(require_manifest "$profile")"
  load_targets
  load_overrides
  case "$saved" in
    desktop/arch-linux/kde-hyprland)
      override_for linux/hyprland >/dev/null || set_override linux/hyprland desktop
      ;;
    laptop/arch-linux/hyprland)
      override_for linux/hyprland >/dev/null || set_override linux/hyprland laptop
      ;;
  esac
  for spec in ${link_overrides[@]+"${link_overrides[@]}"}; do
    group="${spec%%=*}"
    name="${spec#*=}"
    [ -d "$DOTFILES/$group/overrides" ] || die "group has no overrides: $group"
    if [ "$name" != "none" ] && [ ! -d "$DOTFILES/$group/overrides/$name" ]; then
      die "unknown override '$name' for $group (available: $(overrides_list "$group"))"
    fi
    set_override "$group" "$name"
  done
  log "linking profile '$profile'"
  collect_groups "$manifest"
  prune
  local dir pkgdir
  for group in ${LINK_GROUPS[@]+"${LINK_GROUPS[@]}"}; do
    dir="$DOTFILES/$group"
    if [ ! -d "$dir" ]; then
      log "  skip missing group: $group"
      continue
    fi
    for pkgdir in "$dir"/*/; do
      pkgdir="${pkgdir%/}"
      [ "$(basename "$pkgdir")" = "overrides" ] && continue
      if [ -e "$pkgdir/.nolink" ]; then
        log "  skip (.nolink): $group/$(basename "$pkgdir")"
        continue
      fi
      link_package "$pkgdir" "$group/$(basename "$pkgdir")"
    done
  done
  if [ "$DRY" = 0 ]; then
    mkdir -p "$STATE_DIR"
    printf '%s\n' "$profile" > "$STATE_DIR/profile"
    save_overrides
  fi
  if [ "${#CONFLICTS[@]}" -gt 0 ]; then
    echo
    echo "conflicts (existing files not owned by dotfiles):"
    printf '  %s\n' "${CONFLICTS[@]}"
    echo "move each aside and re-run: mv <file> <file>.bak && dotfile link $profile"
    exit 1
  fi
  log "done"
}

cmd_status() {
  local profile
  profile="$(resolve_profile "${1:-}")"
  local manifest
  manifest="$(require_manifest "$profile")"
  load_targets
  load_overrides
  collect_groups "$manifest"
  local group dir pkgdir pkg f rel full dst ok=0 missing=0 bad=0
  for group in ${LINK_GROUPS[@]+"${LINK_GROUPS[@]}"}; do
    dir="$DOTFILES/$group"
    [ -d "$dir" ] || continue
    for pkgdir in "$dir"/*/; do
      pkgdir="${pkgdir%/}"
      pkg="$(basename "$pkgdir")"
      [ "$pkg" = "overrides" ] && continue
      [ -e "$pkgdir/.nolink" ] && continue
      while IFS= read -rd '' f; do
        [ "$(basename "$f")" = ".nolink" ] && continue
        rel="${f#"$pkgdir"/}"
        full="$group/$pkg/$rel"
        dst="$(map_dst "$full" "$pkg" "$rel")"
        if [ ! -e "$dst" ] && [ ! -L "$dst" ]; then
          log "missing  ${dst/#$HOME/\~}"
          missing=$((missing + 1))
        elif [ "$(realpath_m "$dst")" = "$f" ]; then
          ok=$((ok + 1))
        else
          log "differs  ${dst/#$HOME/\~}"
          bad=$((bad + 1))
        fi
      done < <(find "$pkgdir" \( -type f -o -type l \) -print0)
    done
  done
  log "profile '$profile': $ok linked, $missing missing, $bad differing"
  [ $((missing + bad)) -eq 0 ]
}

conf_mode() {
  case "$1" in
    */hypr/*|*/hypr-local.conf|hypr*.conf) printf '%s\n' hypr ;;
    */kitty/colors-*.conf|*/colors-*.conf) printf '%s\n' plain ;;
    */kitty/*.conf|*/kitty.conf) printf '%s\n' kitty ;;
    *) printf '%s\n' plain ;;
  esac
}

format_conf_stream() {
  local mode
  mode="$(conf_mode "$1")"
  awk -v mode="$mode" '
    function compact(s, out, i, ch, quote, escaped, space) {
      out = ""
      quote = ""
      escaped = 0
      space = 0
      for (i = 1; i <= length(s); i++) {
        ch = substr(s, i, 1)
        if (quote != "") {
          out = out ch
          if (escaped) {
            escaped = 0
          } else if (ch == "\\") {
            escaped = 1
          } else if (ch == quote) {
            quote = ""
          }
        } else if (ch == "\"" || ch == "\047") {
          if (space && length(out)) out = out " "
          space = 0
          quote = ch
          out = out ch
        } else if (ch == " " || ch == "\t") {
          space = 1
        } else {
          if (space && length(out)) out = out " "
          space = 0
          out = out ch
        }
      }
      return out
    }

    function indentation(level, out, i) {
      out = ""
      for (i = 0; i < level; i++) out = out "    "
      return out
    }

    function padding(width, out, i) {
      out = ""
      for (i = 0; i < width; i++) out = out " "
      return out
    }

    function kitty_store(s, pos, key, tail, shortcut) {
      s = compact(s)
      if (kitty_blank && kitty_count) kitty_lines[++kitty_count] = ""
      kitty_blank = 0
      kitty_lines[++kitty_count] = s
      if (s ~ /^#/ || !(pos = index(s, " "))) return
      key = substr(s, 1, pos - 1)
      if (key == "map") {
        tail = substr(s, pos + 1)
        pos = index(tail, " ")
        if (!pos) return
        shortcut = substr(tail, 1, pos - 1)
        if (length(shortcut) > kitty_map_width) kitty_map_width = length(shortcut)
      } else if (length(key) > kitty_key_width) {
        kitty_key_width = length(key)
      }
    }

    function kitty_print(i, s, pos, key, value, tail, shortcut, action) {
      for (i = 1; i <= kitty_count; i++) {
        s = kitty_lines[i]
        if (s == "" || s ~ /^#/ || !(pos = index(s, " "))) {
          print s
          continue
        }
        key = substr(s, 1, pos - 1)
        value = substr(s, pos + 1)
        if (key != "map") {
          print key padding(kitty_key_width - length(key) + 2) value
          continue
        }
        tail = value
        pos = index(tail, " ")
        if (!pos) {
          print s
          continue
        }
        shortcut = substr(tail, 1, pos - 1)
        action = substr(tail, pos + 1)
        print "map " shortcut padding(kitty_map_width - length(shortcut) + 2) action
      }
    }

    function hypr_line(s, pos, lhs, rhs) {
      sub(/^[ \t]+/, "", s)
      if (s == "}") indent--
      if (indent < 0) indent = 0
      if (s !~ /^#/ && (pos = index(s, "="))) {
        lhs = substr(s, 1, pos - 1)
        rhs = substr(s, pos + 1)
        sub(/[ \t]+$/, "", lhs)
        sub(/^[ \t]+/, "", rhs)
        if (lhs ~ /^[$[:alnum:]_.:-]+$/) s = lhs " =" (length(rhs) ? " " rhs : "")
      }
      s = indentation(indent) s
      if (s !~ /^[ \t]*#/ && s ~ /\{[ \t]*$/) indent++
      return s
    }

    {
      sub(/[ \t]+$/, "")
      if (mode == "kitty") {
        if ($0 == "") {
          if (kitty_count) kitty_blank = 1
        } else {
          kitty_store($0)
        }
        next
      }
      if ($0 == "") {
        if (printed) blank = 1
        next
      }
      line = $0
      closing = line
      sub(/^[ \t]+/, "", closing)
      if (blank && !(mode == "hypr" && closing == "}")) print ""
      blank = 0
      if (mode == "hypr") line = hypr_line(line)
      print line
      printed = 1
    }

    END {
      if (mode == "kitty") kitty_print()
    }
  '
}

FORMAT_CHANGED=0

format_conf_file() {
  local file="$1" temp
  [ -f "$file" ] || die "not a file: $file"
  case "$file" in
    *.conf) ;;
    *) die "not a .conf file: $file" ;;
  esac
  temp="$(mktemp "${TMPDIR:-/tmp}/dotfile-format.XXXXXX")"
  format_conf_stream "$file" < "$file" > "$temp"
  if ! cmp -s "$file" "$temp"; then
    command cat "$temp" > "$file"
    log "  format ${file/#$DOTFILES\//}"
    FORMAT_CHANGED=$((FORMAT_CHANGED + 1))
  fi
  rm "$temp"
}

cmd_format() {
  if [ "${1:-}" = "--stdin" ]; then
    [ "$#" -eq 2 ] || die "usage: dotfile format --stdin <filename>"
    format_conf_stream "$2"
    return
  fi

  local paths=() path file
  if [ "$#" -eq 0 ]; then
    while IFS= read -rd '' path; do
      paths+=("$DOTFILES/$path")
    done < <(git -C "$DOTFILES" ls-files -z -- '*.conf')
  else
    for path in "$@"; do
      if [ -d "$path" ]; then
        while IFS= read -rd '' file; do paths+=("$file"); done < <(find "$path" -type f -name '*.conf' -print0)
      else
        paths+=("$path")
      fi
    done
  fi

  [ "${#paths[@]}" -gt 0 ] || die "no .conf files found"
  for file in "${paths[@]}"; do format_conf_file "$file"; done
  log "formatted $FORMAT_CHANGED of ${#paths[@]} config files"
}

cmd_add() {
  local group="shared" pkgflag="" description="" path=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --shared) group="shared" ;;
      --linux) group="linux/common" ;;
      --kde) group="linux/kde" ;;
      --hyprland) group="linux/hyprland" ;;
      --server) group="linux/server" ;;
      --macos) group="macos" ;;
      --pkg)
        shift
        pkgflag="${1:-}"
        [ -n "$pkgflag" ] || die "--pkg needs a name"
        ;;
      --description|--desc)
        shift
        description="${1:-}"
        [ -n "$description" ] || die "--description needs text"
        ;;
      -*) die "unknown flag: $1" ;;
      *)
        [ -z "$path" ] || die "expected a single path"
        path="$1"
        ;;
    esac
    shift
  done
  [ -n "$path" ] || die "usage: dotfile add [flags] <path>"
  path="${path/#\~/$HOME}"

  local src=""
  if [ -e "$path" ] || [ -L "$path" ]; then
    case "$path" in
      /*) src="$path" ;;
      *) src="$PWD/$path" ;;
    esac
  elif [ -e "$HOME/.config/$path" ]; then
    src="$HOME/.config/$path"
  else
    local matches=("$HOME/.config/$path"*)
    if [ "${#matches[@]}" -eq 1 ]; then
      src="${matches[0]}"
    elif [ "${#matches[@]}" -gt 1 ]; then
      die "ambiguous, matches: ${matches[*]#"$HOME/.config/"}"
    fi
  fi
  [ -n "$src" ] || die "not found: $path (looked in ~/.config)"
  src="$(canon "$src")"

  if [ -L "$src" ]; then
    case "$(resolve_link "$src")" in
      "$DOTFILES"/*) die "already managed: ${src/#$HOME/\~}" ;;
      *) die "refusing to adopt a foreign symlink: ${src/#$HOME/\~}" ;;
    esac
  fi
  if [ -d "$src" ]; then
    local l
    while IFS= read -rd '' l; do
      case "$(resolve_link "$l")" in
        "$DOTFILES"/*) die "already partially managed (${l/#$HOME/\~}), add individual files instead" ;;
      esac
    done < <(find "$src" -type l -print0)
  fi

  load_targets
  local rel pkg destrel mapline=""
  case "$src" in
    "$HOME/.config/"*)
      rel="${src#"$HOME/.config/"}"
      case "$rel" in
        */*)
          pkg="${pkgflag:-${rel%%/*}}"
          destrel="$group/$pkg/${rel#*/}"
          ;;
        *)
          if [ -d "$src" ]; then
            pkg="${pkgflag:-$rel}"
            destrel="$group/$pkg"
            [ -e "$DOTFILES/$destrel" ] && die "package exists: $destrel (add files inside it individually)"
          else
            pkg="${pkgflag:-${rel%%.*}}"
            destrel="$group/$pkg/$rel"
            mapline="$group/$pkg = ~/.config"
          fi
          ;;
      esac
      ;;
    "$HOME/"*)
      [ -n "$pkgflag" ] || die "files outside ~/.config need --pkg <name>"
      pkg="$pkgflag"
      destrel="$group/$pkg/$(basename "$src")"
      mapline="$destrel = ${src/#$HOME/\~}"
      ;;
    *) die "source must live under \$HOME" ;;
  esac

  local dest="$DOTFILES/$destrel"
  [ -e "$dest" ] && die "destination exists: $destrel"
  case "$description" in
    *$'\n'*|*$'\r'*) die "description must be a single line" ;;
  esac
  load_package_metadata
  if [ -n "$description" ]; then
    set_package_description "$group/$pkg" "$description"
  fi
  mkdir -p "$(dirname "$dest")"
  mv "$src" "$dest"
  ln -s "$dest" "$src"
  log "moved  ${src/#$HOME/\~} -> $destrel"
  log "linked ${src/#$HOME/\~}"
  if [ -n "$mapline" ] && ! grep -qxF "$mapline" "$TARGETS_FILE" 2>/dev/null; then
    printf '%s\n' "$mapline" >> "$TARGETS_FILE"
    log "mapped $mapline"
  fi
  git -C "$DOTFILES" add "$dest" "$TARGETS_FILE" 2>/dev/null || true
  PACKAGE_FILES_CHANGED=0
  sync_packages
  git -C "$DOTFILES" add "$PACKAGES_CONFIG" "$PACKAGES_DOC" 2>/dev/null || true

  local profile manifest
  profile="$(resolve_profile "")"
  manifest="$DOTFILES/environment/$profile/manifest"
  if [ -f "$manifest" ] && ! manifest_groups "$manifest" | grep -qxF "$group"; then
    log "note: group '$group' is not in environment/$profile/manifest, it will not be linked by 'dotfile link' on this machine"
  fi
}

cmd="${1:-help}"
shift || true
case "$cmd" in
  link) cmd_link "$@" ;;
  add) cmd_add "$@" ;;
  packages) cmd_packages "$@" ;;
  format) cmd_format "$@" ;;
  status) cmd_status "$@" ;;
  help|-h|--help) usage ;;
  *)
    usage >&2
    exit 1
    ;;
esac
